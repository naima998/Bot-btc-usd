  <!-- JOURNAL -->
  <div class="tab-panel" id="panel-journal">
    <div class="stats-row">
      <div class="stat-box"><div class="stat-val" id="statTotal">0</div><div class="stat-label">Total Trade</div></div>
      <div class="stat-box"><div class="stat-val" id="statWinrate" style="color:var(--accent);">0%</div><div class="stat-label">Win Rate</div></div>
      <div class="stat-box"><div class="stat-val" id="statPnl">0</div><div class="stat-label">W / L</div></div>
    </div>

    <div class="card">
      <div class="card-title">Catat Trade Baru</div>
      <div class="journal-form">
        <div>
          <label>Side</label>
          <select id="jSide"><option value="BUY">BUY</option><option value="SELL">SELL</option></select>
        </div>
        <div>
          <label>Hasil</label>
          <select id="jResult"><option value="WIN">Win</option><option value="LOSS">Loss</option><option value="BE">Break Even</option></select>
        </div>
        <div>
          <label>Entry</label>
          <input type="number" id="jEntry" placeholder="65000" step="0.01">
        </div>
