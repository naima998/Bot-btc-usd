<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>BTC/USD AI Bot</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0a0c10;
    --surface:#12151b;
    --surface2:#171b22;
    --border:#1f242c;
    --text:#e8eaed;
    --text2:#8b92a0;
    --text3:#5a6170;
    --accent:#f7931a;
    --accent-dim:#7a4d0e;
    --buy:#16c784;
    --sell:#ea3943;
    --buy-bg:rgba(22,199,132,0.1);
    --sell-bg:rgba(234,57,67,0.1);
  }
  *{box-sizing:border-box; margin:0; padding:0; -webkit-tap-highlight-color:transparent;}
  body{
    background:var(--bg); color:var(--text);
    font-family:'Inter',sans-serif;
    min-height:100vh;
    padding-bottom:90px;
  }
  .mono{font-family:'JetBrains Mono',monospace;}

  /* Ticker header */
  header{
    position:sticky; top:0; z-index:50;
    background:linear-gradient(180deg, #0d1015 0%, #0a0c10 100%);
    border-bottom:1px solid var(--border);
    padding:14px 16px 12px;
  }
  .ticker-row{display:flex; align-items:center; justify-content:space-between; gap:10px;}
  .ticker-left{display:flex; align-items:center; gap:10px;}
  .btc-icon{
    width:34px; height:34px; border-radius:50%;
    background:linear-gradient(135deg,#f7931a,#c9700a);
    display:flex; align-items:center; justify-content:center;
    font-weight:800; font-size:16px; color:#0a0c10;
    flex-shrink:0;
  }
  .pair-name{font-size:13px; color:var(--text2); font-weight:600; letter-spacing:0.3px;}
  .live-dot{
    width:7px; height:7px; border-radius:50%; background:var(--buy);
    display:inline-block; margin-right:5px;
    animation:pulse 1.6s ease-in-out infinite;
  }
  @keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(22,199,132,0.5);}50%{opacity:0.6;box-shadow:0 0 0 4px rgba(22,199,132,0);}}
  .price-block{text-align:right;}
  .price{font-size:26px; font-weight:700; letter-spacing:-0.5px; transition:color 0.3s;}
  .change{font-size:12px; font-weight:600; margin-top:2px;}
  .flash-up{animation:flashUp 0.6s ease;}
  .flash-down{animation:flashDown 0.6s ease;}
  @keyframes flashUp{0%{color:var(--buy);}100%{color:var(--text);}}
  @keyframes flashDown{0%{color:var(--sell);}100%{color:var(--text);}}

  .sub-row{display:flex; gap:8px; margin-top:10px; overflow-x:auto;}
  .pill{
    background:var(--surface); border:1px solid var(--border);
    border-radius:20px; padding:5px 11px;
    font-size:11px; color:var(--text2); white-space:nowrap;
    display:flex; align-items:center; gap:5px;
  }
  .pill b{color:var(--text); font-weight:700;}
  .fng-fear{color:var(--sell);} .fng-greed{color:var(--buy);} .fng-neutral{color:var(--accent);}

  main{padding:16px;}
  .card{
    background:var(--surface); border:1px solid var(--border);
    border-radius:14px; padding:16px; margin-bottom:14px;
  }
  .card-title{font-size:11px; text-transform:uppercase; letter-spacing:1px; color:var(--text3); font-weight:700; margin-bottom:12px;}

  /* Signal card */
  .signal-badge{
    display:inline-flex; align-items:center; gap:8px;
    padding:10px 18px; border-radius:10px; font-size:20px; font-weight:800;
    letter-spacing:1px; margin-bottom:10px;
  }
  .signal-buy{background:var(--buy-bg); color:var(--buy); border:1px solid rgba(22,199,132,0.3);}
  .signal-sell{background:var(--sell-bg); color:var(--sell); border:1px solid rgba(234,57,67,0.3);}
  .signal-hold{background:rgba(247,147,26,0.1); color:var(--accent); border:1px solid rgba(247,147,26,0.3);}
  .confidence-bar{height:6px; background:var(--surface2); border-radius:4px; overflow:hidden; margin:8px 0 14px;}
  .confidence-fill{height:100%; border-radius:4px; transition:width 0.5s;}
  .levels{display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-top:6px;}
  .level-box{background:var(--surface2); border-radius:10px; padding:10px; text-align:center;}
  .level-label{font-size:10px; color:var(--text3); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:4px;}
  .level-val{font-size:14px; font-weight:700;}
  .warn-note{
    margin-top:12px; padding:9px 11px; background:rgba(247,147,26,0.08);
    border-left:3px solid var(--accent); border-radius:6px;
    font-size:12px; color:#d9ad6e; line-height:1.5;
  }

  /* sparkline */
  canvas#spark{width:100%; height:60px; display:block; margin-top:10px;}

  /* tabs */
  .tabs{display:flex; gap:6px; margin-bottom:14px;}
  .tab-btn{
    flex:1; background:var(--surface); border:1px solid var(--border); color:var(--text2);
    padding:10px 4px; border-radius:10px; font-size:12px; font-weight:600;
    text-align:center; cursor:pointer;
  }
  .tab-btn.active{background:var(--accent); color:#1a1100; border-color:var(--accent);}
  .tab-panel{display:none;}
  .tab-panel.active{display:block;}

  /* multi timeframe */
  .tf-grid{display:grid; grid-template-columns:1fr 1fr; gap:10px;}
  .tf-card{background:var(--surface2); border-radius:10px; padding:12px;}
  .tf-name{font-size:11px; color:var(--text3); font-weight:700; margin-bottom:6px;}
  .tf-trend{font-size:15px; font-weight:800; margin-bottom:4px;}
  .tf-trend.up{color:var(--buy);} .tf-trend.down{color:var(--sell);}
  .tf-detail{font-size:11px; color:var(--text2);}
  .tf-fresh{display:inline-block; margin-top:5px; font-size:9px; padding:2px 6px; border-radius:8px; background:rgba(247,147,26,0.15); color:var(--accent); font-weight:700;}

  /* AI engine */
  .seg{display:flex; background:var(--surface2); border-radius:10px; padding:3px; margin-bottom:12px;}
  .seg-btn{flex:1; text-align:center; padding:9px; border-radius:8px; font-size:13px; font-weight:600; color:var(--text2); cursor:pointer;}
  .seg-btn.active{background:var(--accent); color:#1a1100;}
  input[type=password], input[type=text], input[type=number], select{
    width:100%; background:var(--surface2); border:1px solid var(--border); color:var(--text);
    padding:11px 12px; border-radius:9px; font-size:13px; margin-bottom:10px;
    font-family:'Inter',sans-serif;
  }
  input::placeholder{color:var(--text3);}
  label{font-size:11px; color:var(--text2); font-weight:600; display:block; margin-bottom:6px;}
  .btn{
    width:100%; background:var(--accent); color:#1a1100; border:none;
    padding:13px; border-radius:10px; font-size:14px; font-weight:700;
    cursor:pointer; letter-spacing:0.2px;
  }
  .btn:disabled{opacity:0.5;}
  .btn-secondary{background:var(--surface2); color:var(--text); border:1px solid var(--border);}
  .ai-output{
    margin-top:12px; background:var(--surface2); border-radius:10px; padding:13px;
    font-size:13px; line-height:1.6; color:var(--text); white-space:pre-wrap; min-height:40px;
  }
  .ai-output.empty{color:var(--text3); font-style:italic;}
  .small-note{font-size:11px; color:var(--text3); margin-top:8px; line-height:1.5;}

  /* journal */
  .journal-form{display:grid; grid-template-columns:1fr 1fr; gap:10px;}
  .journal-form .full{grid-column:1/-1;}
  .stats-row{display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom:14px;}
  .stat-box{background:var(--surface2); border-radius:10px; padding:12px; text-align:center;}
  .stat-val{font-size:20px; font-weight:800;}
  .stat-label{font-size:10px; color:var(--text3); text-transform:uppercase; margin-top:3px;}
  .trade-item{
    display:flex; justify-content:space-between; align-items:center;
    padding:11px 0; border-bottom:1px solid var(--border);
  }
  .trade-item:last-child{border-bottom:none;}
  .trade-side{font-size:11px; font-weight:800; padding:3px 8px; border-radius:6px;}
  .side-buy{background:var(--buy-bg); color:var(--buy);}
  .side-sell{background:var(--sell-bg); color:var(--sell);}
  .trade-meta{font-size:11px; color:var(--text3); margin-top:2px;}
  .result-win{color:var(--buy); font-weight:700; font-size:12px;}
  .result-loss{color:var(--sell); font-weight:700; font-size:12px;}
  .result-be{color:var(--text2); font-weight:700; font-size:12px;}
  .del-btn{background:none; border:none; color:var(--text3); font-size:16px; padding:4px 8px; cursor:pointer;}
  .empty-state{text-align:center; padding:30px 10px; color:var(--text3); font-size:13px;}

  .reminder-card{
    background:linear-gradient(135deg, rgba(247,147,26,0.07), rgba(247,147,26,0.02));
    border:1px solid rgba(247,147,26,0.2);
  }
  .reminder-list{font-size:12.5px; color:var(--text2); line-height:1.9; padding-left:18px;}

  footer{padding:16px; text-align:center; font-size:10.5px; color:var(--text3);}
</style>
</head>
