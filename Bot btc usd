</main>

<footer>BTC/USD AI Bot · Data: Binance Public API · Bukan saran finansial, selalu manage risiko sendiri.</footer>

<script>
/* ====================== CONFIG ====================== */
const SYMBOL = "BTCUSDT";
const TF_LIST = [
  {key:"1d", label:"Daily (D1)"},
  {key:"4h", label:"4 Jam (H4)"},
  {key:"1h", label:"1 Jam (H1)"},
  {key:"15m", label:"15 Menit (M15)"}
];

let state = {
  price: null,
  prevPrice: null,
  change24h: null,
  tfData: {},
  primaryATR: null,
  primaryRSI: null,
  signal: null,
  sparkCloses: []
};

/* ====================== INDICATORS ====================== */
function calcEMA(closes, period){
  const k = 2/(period+1);
  let ema = closes[0];
  const series = [ema];
  for(let i=1;i<closes.length;i++){
    ema = closes[i]*k + ema*(1-k);
    series.push(ema);
  }
  return series;
}

function calcRSI(closes, period=14){
  if(closes.length < period+1) return 50;
  let gains=[], losses=[];
  for(let i=1;i<closes.length;i++){
    const diff = closes[i]-closes[i-1];
    gains.push(Math.max(diff,0));
    losses.push(Math.max(-diff,0));
  }
  let avgGain = gains.slice(0,period).reduce((a,b)=>a+b,0)/period;
  let avgLoss = losses.slice(0,period).reduce((a,b)=>a+b,0)/period;
  for(let i=period;i<gains.length;i++){
    avgGain = (avgGain*(period-1)+gains[i])/period;
    avgLoss = (avgLoss*(period-1)+losses[i])/period;
  }
  if(avgLoss===0) return 100;
  const rs = avgGain/avgLoss;
  return 100 - (100/(1+rs));
}

function calcATR(highs, lows, closes, period=14){
  let trs=[];
  for(let i=1;i<closes.length;i++){
    const tr = Math.max(
      highs[i]-lows[i],
      Math.abs(highs[i]-closes[i-1]),
      Math.abs(lows[i]-closes[i-1])
    );
    trs.push(tr);
  }
  let atr = trs.slice(0,period).reduce((a,b)=>a+b,0)/period;
  for(let i=period;i<trs.length;i++){
    atr = (atr*(period-1)+trs[i])/period;
  }
  return atr;
}

/* ====================== DATA FETCH ====================== */
async function fetchPrice(){
  try{
    const res = await fetch(`https://api.binance.com/api/v3/ticker/24hr?symbol=${SYMBOL}`);
    const d = await res.json();
    state.prevPrice = state.price;
    state.price = parseFloat(d.lastPrice);
    state.change24h = parseFloat(d.priceChangePercent);
    renderTicker();
  }catch(e){
    document.getElementById('priceEl').textContent = "Error";
    console.error("fetchPrice error", e);
  }
}

async function fetchKlines(interval, limit=100){
  const res = await fetch(`https://api.binance.com/api/v3/klines?symbol=${SYMBOL}&interval=${interval}&limit=${limit}`);
  const raw = await res.json();
  return {
    opens: raw.map(r=>parseFloat(r[1])),
    highs: raw.map(r=>parseFloat(r[2])),
    lows: raw.map(r=>parseFloat(r[3])),
    closes: raw.map(r=>parseFloat(r[4])),
  };
}

async function fetchFearGreed(){
  try{
    const res = await fetch("https://api.alternative.me/fng/?limit=1");
    const d = await res.json();
    const item = d.data[0];
    const val = item.value;
    const cls = item.value_classification;
    const fngEl = document.getElementById('fngVal');
    const pillEl = document.getElementById('fngPill');
    fngEl.textContent = `${val} (${cls})`;
    pillEl.classList.remove('fng-fear','fng-greed','fng-neutral');
    if(val < 40) pillEl.classList.add('fng-fear');
    else if(val > 60) pillEl.classList.add('fng-greed');
    else pillEl.classList.add('fng-neutral');
  }catch(e){
    document.getElementById('fngVal').textContent = "N/A";
  }
}

/* ====================== ANALYSIS ====================== */
async function runFullAnalysis(){
  document.getElementById('tfGrid').innerHTML = '<div class="empty-state">Memuat data timeframe...</div>';
  let bullishCount = 0;
  let tfResults = [];

  for(const tf of TF_LIST){
    try{
      const k = await fetchKlines(tf.key, 100);
      const emaFast = calcEMA(k.closes, 9);
      const emaSlow = calcEMA(k.closes, 21);
      const last = emaFast.length-1;
      const trendUp = emaFast[last] > emaSlow[last];
      const prevTrendUp = emaFast[last-1] > emaSlow[last-1];
      const freshCross = trendUp !== prevTrendUp;
      const rsi = calcRSI(k.closes, 14);
      if(trendUp) bullishCount++;

      tfResults.push({
        key: tf.key, label: tf.label, trendUp, rsi, freshCross,
        emaFast: emaFast[last], emaSlow: emaSlow[last]
      });

      if(tf.key === "1h"){
        state.primaryATR = calcATR(k.highs, k.lows, k.closes, 14);
        state.primaryRSI = rsi;
        state.sparkCloses = k.closes.slice(-50);
      }
    }catch(e){
      console.error("TF fetch error", tf.key, e);
    }
  }

  state.tfData = tfResults;
  renderTimeframes(tfResults);

  const total = tfResults.length || 4;
  let signalType, confidence;
  if(bullishCount >= 3){ signalType = "BUY"; confidence = Math.round((bullishCount/total)*100); }
  else if(bullishCount <= 1){ signalType = "SELL"; confidence = Math.round(((total-bullishCount)/total)*100); }
  else { signalType = "HOLD"; confidence = 50; }

  let warn = "";
  if(signalType === "BUY" && state.primaryRSI > 70) warn = "⚠️ RSI 1H sudah overbought (>70). Pertimbangkan tunggu pullback sebelum entry.";
  if(signalType === "SELL" && state.primaryRSI < 30) warn = "⚠️ RSI 1H sudah oversold (<30). Pertimbangkan tunggu pantulan sebelum entry.";

  const price = state.price;
  const atr = state.primaryATR || price*0.005;
  let entry, sl, tp;
  if(signalType === "BUY"){
    entry = price; sl = price - 1.5*atr; tp = price + 3*atr;
  } else if(signalType === "SELL"){
    entry = price; sl = price + 1.5*atr; tp = price - 3*atr;
  } else {
    entry = price; sl = price - 1.5*atr; tp = price + 1.5*atr;
  }

  state.signal = {type: signalType, confidence, entry, sl, tp, warn};
  renderSignal();
  drawSpark();
}

/* ====================== RENDER ====================== */
function renderTicker(){
  const priceEl = document.getElementById('priceEl');
  const changeEl = document.getElementById
